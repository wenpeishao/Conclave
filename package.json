{
  "name": "conclave",
  "version": "0.1.0",
  "type": "module",
  "description": "A cross-device, model-agnostic bus for AI coding agents — Claude Code, Codex, Gemini, local models, and humans collaborating across machines over one protocol. Pluggable transports (WebSocket relay or git), a shared task board, a deployable auth'd server, durable replay.",
  "license": "MIT",
  "author": "Wenpei Shao",
  "keywords": [
    "ai-agents",
    "multi-agent",
    "agent-collaboration",
    "claude-code",
    "mcp",
    "cross-device",
    "websocket",
    "task-board",
    "agent-bus"
  ],
  "homepage": "https://github.com/wenpeishao/conclave#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wenpeishao/conclave.git"
  },
  "bugs": {
    "url": "https://github.com/wenpeishao/conclave/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "conclave": "src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 --test-force-exit test/*.test.ts",
    "test:live": "node --import tsx --test --test-concurrency=1 --test-force-exit test/live/*.test.ts",
    "example": "tsx examples/api-alignment/demo.ts",
    "conclave": "tsx src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
